{
  "name": "sportz-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test --grep-invert @deployed",
    "test:e2e:ui": "playwright test --grep-invert @deployed --ui",
    "test:e2e:deployed": "PLAYWRIGHT_NO_SERVER=1 PLAYWRIGHT_BASE_URL=https://sportz-ui.vercel.app playwright test --grep @deployed",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@newrelic/browser-agent": "^1.316.0",
    "@sentry/nextjs": "^10.59.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-virtual": "^3.14.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "geist": "^1.7.2",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.391.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.43",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.9.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
